Private Sub CmdSave_Click()
    If (Val(xCash.Text) + Val(xVisa.Text)) = Val(Vs_Inv.xDisc.Text) + Val(Vs_Inv.xTotItem.Text) Then
        Unload Me
    Else
        MsgBox "Ńč╩╠┌╔ ▐ĒŃ╔ ŪßėŽŪŽ ßß╚µõ"
    End If
End Sub
Private Sub Form_KeyPress(KeyAscii As Integer)
If KeyAscii = 13 Then
    If TypeOf ActiveControl Is TextBox Or TypeOf ActiveControl Is DBCombo Then SendKeys "{TAB}"
End If
End Sub

