Dim nOption As Integer
Private Sub CmdApply_Click()
publicFlag = nOption
Select Case nOption
Case 1
    Rep1_1.Show 1
Case 2
    Rep1_2.Show 1
Case 3
    Rep1_3.Show 1
Case 4
    Rep1_3.Show 1
Case 5
    Load Rep1_3
    Rep1_3.store.Visible = True
    Rep1_3.LblStore.Visible = True
'    Rep1_3.Store2.Visible = True
'    Rep1_3.LblStore2.Visible = True
    Rep1_3.Show 1
Case 6
    Rep1_6.Show 1
Case 7
    Rep1_7.Show 1
Case 8
    Rep1_8.Show 1
Case 9
    Rep1_9.Show 1
Case 10
    Load TransRep
    TransRep.Show 1

Case 13
    Rep1_13.Show 1
Case 14
    Rep1_14.Show 1

Case 15
    Load Rep1_3
    Rep1_3.store.Visible = False
    Rep1_3.LblStore.Visible = False
    Rep1_3.Show 1

Case 17
    Load Rep1_17
    Rep1_17.Show 1


    Case 18
        Load REP1_18
        REP1_18.Show 1
    Case 19
        Load REP1_19
        REP1_19.Show 1
    Case 20
