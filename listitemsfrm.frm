Attribute VB_Name = "listItemsfrm"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Dim con As New ADODB.Connection
Public nGroup As String, cGroupname As String

Private Sub Form_KeyDown(KeyCode As Integer, Shift As Integer)
If KeyCode = 27 Then
    Unload Me
End If
End Sub

Private Sub Form_Load()
openCon con
Fixgrd
myload
End Sub
Private Sub myload()
grid1.Rows = 0
Me.Caption = "Þ«∆„… «·«’‰«ð" & turn(cGroupname, " - ") & cGroupname
Dim loctable As New ADODB.Recordset, cString As String
cString = "select * from file1_10"
If SalesFrm.Check2.Value = 0 Then
    cString = cString & turn(cString) & " (not file1_10.item2 is null)"
End If
If nGroup <> "" Then
    cString = cString & turn(cString) & " file1_10.[group] = " & nGroup
End If

loctable.Open cString, con, adOpenStatic, adLockReadOnly, adCmdText
nRow = 0
nCol = 0
grid1.Rows = 0
grid2.Rows = 0
Do Until loctable.EOF
    If nCol = 0 Then
        grid1.AddItem ""
        grid2.AddItem ""
    End If
    grid1.TextMatrix(grid1.Rows - 1, nCol) = loctable!Item & ""
    grid2.TextMatrix(grid2.Rows - 1, nCol) = loctable!Desca & ""
    nCol = IIf(nCol = grid1.Cols - 1, 0, nCol + 1)
    loctable.MoveNext
Loop
End Sub
Private Sub Fixgrd()
For i = 0 To grid2.Cols - 1
    grid2.ColWidth(i) = 2040
    grid2.ColAlignment(i) = flexAlignCenterCenter
Next
End Sub
Private Sub Grid2_Click()
If grid2.TextMatrix(grid2.Row, grid2.Col) = "" Then Exit Sub
grid1.Row = grid2.Row
grid1.Col = grid2.Col
SalesFrm.myproc3
Unload Me
End Sub
