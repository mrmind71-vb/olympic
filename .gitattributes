# Force VB6 source files to always use CRLF
*.frm  text eol=crlf
*.FRM  text eol=crlf
*.Frm  text eol=crlf
*.bas  text eol=crlf
*.cls  text eol=crlf
*.ctl  text eol=crlf
*.vbp  text eol=crlf
*.vbw  text eol=crlf
*.dsr  text eol=crlf
*.txt  text eol=crlf

# Treat VB6 binary files as binary (never mangle these)
*.frx  binary
*.FRX  binary
*.res  binary
*.exe  binary
*.dll  binary
*.ocx  binary
*.ctx  binary
*.tlb  binary
