Attribute VB_Name = "Rep_501"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Dim CHQTable As Recordset
Dim ClinTable  As Recordset
Dim TempTable As Recordset
Dim BoxTable As Recordset
Dim lExit As Boolean
Function MYVALID()
MYVALID = True
End Function
Private Sub cmdExit_Click()
Unload Me
End Sub
Private Sub CmdUndo_Click()
xdate1.Text = ""
xDate2.Text = ""
xCode.Text = ""
End Sub
Private Sub CmdGroup_Click()
End Sub
Private Sub Form_Load()
Set TempTable = tempdb.OpenRecordset("TEMP")
Set ClinTable = mydb.OpenRecordset("FILE3_10", dbOpenDynaset)
Set BoxTable = mydb.OpenRecordset("FILE0_50", dbOpenDynaset)
End Sub
Private Sub CmdApply_Click()
Dim cHead As String
cHead = "  "
lExit = False
If Not MYVALID Then Exit Sub
tempdb.Execute "Delete * From Temp"
    
cString = "SELECT FILE3_10.DESCA AS SuppDesc, FILE5_20.DATE_1, FILE5_20.NAME1, FILE5_20.CLOSED, FILE5_20.transname1, FILE5_20.transname2,  " & _
          " FILE5_20.DATE_R, FILE5_20.DATE_3, FILE5_20.VALUE , FILE5_20.BOX " & _
          " FROM FILE5_20 LEFT JOIN FILE3_10 ON FILE5_20.CODE = FILE3_10.CODE  " & _
          "  WHERE file5_20.SER_NO is not null  "
If xdate1.Text <> "" Then cString = cString & " and FILE5_20.DATE_1 >= DateValue(" & MyParn(xdate1.Text) & ")"
If xDate2.Text <> "" Then cString = cString & " and FILE5_20.DATE_1 <= DateValue(" & MyParn(xDate2.Text) & ")"

If xCode.Text <> "" Then
    cString = cString & " AND FILE5_20.CODE = " & MyParn(xCode.Text)
    cHead = cHead & " ··⁄„Ì·  " & xDesca.Caption
End If
Set CHQTable = mydb.CreateSnapshot(cString)
             
With CHQTable
If .RecordCount > 0 Then
    .MoveFirst
    Do While Not .EOF
        If .CLOSED = Val(publicFlag) Then
        TempTable.AddNew
        TempTable.str3 = .NAME1
        TempTable.str2 = .TRANSNAME1
        If IsNull(.TRANSNAME1) Then
            BoxTable.FindFirst " CODE = " & MyParn(.BOX)
            If Not BoxTable.NoMatch Then TempTable.str2 = BoxTable.DESCA
        End If
        TempTable.VAL1 = .Value
        TempTable.Date1 = .date_1
        TempTable.date2 = .date_R
        TempTable.date3 = .date_3
        TempTable.str7 = cHead
        Select Case publicFlag
            Case 0
                TempTable.str6 = "√. Þ. „” ÕÞ… "
            Case 1
                TempTable.str6 = "√. Þ. „— œ… "
            Case 2
                TempTable.str6 = "√. Þ. „Õ’·… "
        End Select
        If xdate1.Text <> "" Then TempTable.str6 = TempTable.str6 & "„‰  «—ÌŒ " & xdate1.Text & " ≈·Ï " & xDate2.Text
        TempTable.str19 = firsttitle
        TempTable.str20 = Secondtitle
        TempTable.Update
        End If
        .MoveNext
    Loop
End If
End With

cString = "SELECT  FILE3_10.DESCA AS SuppDesc , FILE5_21.DATE_1, FILE5_21.NAME12 ,  " & _
          " FILE5_21.CLOSED, FILE5_21.DATE_R, FILE5_21.DATE_3, FILE5_21.VALUE " & _
          " FROM FILE5_21 LEFT JOIN FILE3_10 ON  " & _
          " FILE5_21.CODE2 = FILE3_10.CODE WHERE file5_21.code2 is not null  "
If xdate1.Text <> "" Then cString = cString & " and FILE5_21.DATE_1 >= DateValue(" & MyParn(xdate1.Text) & ")"
If xDate2.Text <> "" Then cString = cString & " and FILE5_21.DATE_1 <= DateValue(" & MyParn(xDate2.Text) & ")"

If xCode.Text <> "" Then
    cString = cString & " AND FILE5_21.CODE2 = " & MyParn(xCode.Text)
    cHead = cHead & " ··⁄„Ì·  " & xDesca.Caption
End If
Set CHQTable = mydb.CreateSnapshot(cString)
             
With CHQTable
If .RecordCount > 0 Then
    .MoveFirst
    Do While Not .EOF
        If .CLOSED = publicFlag Then
        TempTable.AddNew
        TempTable.str3 = .NAME12
        TempTable.str2 = .transname2
        TempTable.VAL2 = .Value
        TempTable.Date1 = .date_1
        TempTable.date2 = .date_R
        TempTable.date3 = .date_3
        TempTable.str7 = cHead
        Select Case publicFlag
            Case 0
                TempTable.str6 = "√. œ. „” ÕÞ… "
            Case 1
                TempTable.str6 = "√. œ. „— œ… "
            Case 2
                TempTable.str6 = "√. œ. „Õ’·… "
        End Select
        If xdate1.Text <> "" Then TempTable.str6 = TempTable.str6 & "„‰  «—ÌŒ " & xdate1.Text & " ≈·Ï " & xDate2.Text
        TempTable.str19 = firsttitle
        TempTable.str20 = Secondtitle
        TempTable.Update
        End If
        .MoveNext
    Loop
End If
End With

Report1.ReportFileName = PublicPath & "\Reports\Rep_501.rpt"
Report1.DataFiles(0) = TempPath
Report1.Action = 1

End Sub
Private Sub xCode_Change()
ClinTable.FindFirst " code = " & MyParn(xCode.Text)
xDesca.Caption = IIf(ClinTable.NoMatch, "", ClinTable.DESCA)
End Sub
Private Sub xCode_DblClick()
    Dim Generalarray(3)
    Dim GrdArray(2)
        
    Set Generalarray(1) = Me
    Generalarray(2) = "Select Code As «·þÊœ,DescA As «·«”„  From FILE3_10   "
    Generalarray(3) = " where  DescA Like '*cFilter*'"
        
    GrdArray(1) = 1000
    GrdArray(2) = 4000
        
    Lookupdata = Array(Generalarray, GrdArray)
    Load Search
    Search.Caption = "«” ⁄·«„ "
    Search.Show 1

End Sub

Private Sub xCODE_KeyUp(KeyCode As Integer, Shift As Integer)
If KeyCode = 112 Then
End If
End Sub
Sub myProc()
If TypeOf ActiveControl Is TextBox Then
    ActiveControl.Text = GrdText(Search.Grid1, 0)
End If
Unload Search
End Sub

