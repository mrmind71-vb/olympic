aSplit = Split(sCode, "-")
If IsEmpty(aSplit) Then Exit Function
If UBound(aSplit) > 1 Then Exit Function
If Not ValidInt(Val(aSplit(0))) Then Exit Function
If UBound(aSplit) = 1 Then
    If Not ValidInt(Val(aSplit(1))) Then Exit Function
End If

