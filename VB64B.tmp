Private Sub CmdUndo_Click()
If CardTable.BOF And CardTable.EOF Then
    myDefine
    Exit Sub
End If
CardTable.Find "Doc_No = " & MyParn(xDoc_No.Text), , adSearchForward, adBookmarkFirst
If CardTable.EOF Then CardTable.MoveLast
MyLoad
